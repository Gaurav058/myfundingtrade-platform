# ──────────────────────────────────────────────────
# MyFundingTrade — API Environment Variables
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myfundingtrade?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT (access token) ──
# MUST be ≥ 32 chars in production. Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Cookies ──
# Secret used to sign httpOnly refresh-token cookies.
COOKIE_SECRET=change-me-cookie-secret
COOKIE_DOMAIN=localhost

# ── CORS / Allowed Origins ──
# Comma-separated. Falls back to individual NEXT_PUBLIC_*_URL values.
# ALLOWED_ORIGINS=https://myfundingtrade.com,https://portal.myfundingtrade.com,https://admin.myfundingtrade.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ── BullMQ (shares Redis connection) ──
REDIS_HOST=localhost
REDIS_PORT=6379
