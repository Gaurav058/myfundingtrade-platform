// ════════════════════════════════════════════════════════════════════════════
// MyFundingTrade — Production Prisma Schema
// Database: PostgreSQL
// PKs: UUID v4
// Conventions: snake_case tables/columns, camelCase TypeScript
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

enum UserRole {
  TRADER
  AFFILIATE
  SUPPORT_AGENT
  KYC_REVIEWER
  FINANCE_ADMIN
  CONTENT_ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  CRYPTO
  BANK_TRANSFER
  MANUAL
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  PASSED
  FAILED
  EXPIRED
  CANCELLED
}

enum TraderAccountStatus {
  PROVISIONING
  ACTIVE
  BREACHED
  PASSED
  FUNDED
  SUSPENDED
  CLOSED
}

enum TraderAccountPhaseType {
  PHASE_1
  PHASE_2
  FUNDED
}

enum EvaluationVerdict {
  IN_PROGRESS
  PASSED
  FAILED_DAILY_LOSS
  FAILED_TOTAL_LOSS
  FAILED_TIME_LIMIT
  FAILED_MIN_DAYS
  FAILED_INACTIVITY
  FAILED_RULE_VIOLATION
}

enum KycStatus {
  NOT_STARTED
  PENDING_DOCUMENTS
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  RESUBMISSION_REQUIRED
}

enum KycDocumentType {
  GOVERNMENT_ID
  PASSPORT
  DRIVERS_LICENSE
  PROOF_OF_ADDRESS
  SELFIE
  BANK_STATEMENT
}

enum PayoutStatus {
  DRAFT
  PENDING_KYC
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
  FAILED
}

enum PayoutMethodType {
  BANK_WIRE
  CRYPTO_WALLET
  PAYPAL
  WISE
  RISE
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum AffiliateConversionStatus {
  PENDING
  CONFIRMED
  REJECTED
  PAID
}

enum CommissionPayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum TicketStatus {
  OPEN
  AWAITING_CUSTOMER
  AWAITING_AGENT
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  ACCOUNT
  BILLING
  TRADING
  KYC
  PAYOUT
  TECHNICAL
  OTHER
}

enum NotificationType {
  EMAIL
  IN_APP
  SMS
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum BlogPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  ESCALATE
  EXPORT
  IMPERSONATE
  SETTINGS_CHANGE
}

enum RestrictionType {
  BLOCKED
  ALLOWED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LegalDocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  RISK_DISCLOSURE
  REFUND_POLICY
  COOKIE_POLICY
  AML_POLICY
  AFFILIATE_AGREEMENT
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  USER & IDENTITY                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// Core identity. One row per registered human.
model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique @db.VarChar(255)
  passwordHash    String        @map("password_hash") @db.VarChar(255)
  role            UserRole      @default(TRADER)
  status          AccountStatus @default(ACTIVE)
  emailVerified   Boolean       @default(false) @map("email_verified")
  twoFactorSecret String?       @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled Boolean      @default(false) @map("two_factor_enabled")
  lastLoginAt     DateTime?     @map("last_login_at")
  lastLoginIp     String?       @map("last_login_ip") @db.VarChar(45)
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  profile             UserProfile?
  sessions            Session[]
  refreshTokens       RefreshToken[]
  orders              Order[]
  traderAccounts      TraderAccount[]
  kycSubmissions      KycSubmission[]
  payoutRequests      PayoutRequest[]
  payoutMethods       PayoutMethod[]
  affiliateAccount    AffiliateAccount?
  tickets             SupportTicket[]      @relation("TicketCreator")
  assignedTickets     SupportTicket[]      @relation("TicketAssignee")
  ticketMessages      SupportMessage[]
  notifications       Notification[]
  legalConsents       LegalConsent[]
  adminActions        AdminActionLog[]     @relation("ActionPerformer")
  adminActionsTarget  AdminActionLog[]     @relation("ActionTarget")
  blogPosts           BlogPost[]

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

/// Extended profile data separated from auth identity.
model UserProfile {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  firstName     String    @map("first_name") @db.VarChar(100)
  lastName      String    @map("last_name") @db.VarChar(100)
  phone         String?   @db.VarChar(30)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  country       String?   @db.VarChar(2) // ISO 3166-1 alpha-2
  state         String?   @db.VarChar(100)
  city          String?   @db.VarChar(100)
  addressLine1  String?   @map("address_line_1") @db.VarChar(255)
  addressLine2  String?   @map("address_line_2") @db.VarChar(255)
  postalCode    String?   @map("postal_code") @db.VarChar(20)
  timezone      String?   @db.VarChar(50)
  avatarUrl     String?   @map("avatar_url") @db.VarChar(500)
  bio           String?   @db.Text
  referralCode  String?   @unique @map("referral_code") @db.VarChar(20)
  referredById  String?   @map("referred_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([referralCode])
  @@map("user_profiles")
}

/// Server-side session tracking for security + concurrent session control.
model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  ipAddress   String    @map("ip_address") @db.VarChar(45)
  userAgent   String    @map("user_agent") @db.VarChar(500)
  fingerprint String?   @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Refresh tokens stored server-side for rotation + revocation.
model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  family      String    @db.VarChar(255) // token family for rotation detection
  ipAddress   String    @map("ip_address") @db.VarChar(45)
  userAgent   String    @map("user_agent") @db.VarChar(500)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  replacedBy  String?   @map("replaced_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([family])
  @@map("refresh_tokens")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  CHALLENGE PLANS & RULES                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// A product line (e.g. "Standard Challenge", "Rapid Challenge").
model ChallengePlan {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(100)
  slug         String    @unique @db.VarChar(120)
  description  String?   @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  sortOrder    Int       @default(0) @map("sort_order")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  variants     ChallengeVariant[]

  @@index([isActive])
  @@map("challenge_plans")
}

/// A purchasable SKU: plan × account size (e.g. "Standard $50K", "Rapid $100K").
model ChallengeVariant {
  id              String    @id @default(uuid()) @db.Uuid
  planId          String    @map("plan_id") @db.Uuid
  ruleSetId       String    @map("rule_set_id") @db.Uuid
  accountSize     Int       @map("account_size") // in dollars
  price           Decimal   @db.Decimal(10, 2)
  currency        String    @default("USD") @db.VarChar(3)
  leverage        Int       @default(100)
  profitSplit     Decimal   @default(80) @map("profit_split") @db.Decimal(5, 2)
  phases          Int       @default(2)
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  plan            ChallengePlan    @relation(fields: [planId], references: [id])
  ruleSet         ChallengeRuleSet @relation(fields: [ruleSetId], references: [id])
  orders          Order[]
  traderAccounts  TraderAccount[]

  @@unique([planId, accountSize])
  @@index([isActive])
  @@map("challenge_variants")
}

/// Evaluation rules applied to a variant per phase.
model ChallengeRuleSet {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @db.VarChar(100)
  profitTargetPct       Decimal   @map("profit_target_pct") @db.Decimal(5, 2)
  maxDailyLossPct       Decimal   @map("max_daily_loss_pct") @db.Decimal(5, 2)
  maxTotalLossPct       Decimal   @map("max_total_loss_pct") @db.Decimal(5, 2)
  minTradingDays        Int       @map("min_trading_days")
  maxCalendarDays       Int?      @map("max_calendar_days")
  maxInactivityDays     Int       @default(14) @map("max_inactivity_days")
  allowWeekendHolding   Boolean   @default(false) @map("allow_weekend_holding")
  allowNewsTrading      Boolean   @default(true) @map("allow_news_trading")
  allowExpertAdvisors   Boolean   @default(true) @map("allow_expert_advisors")
  allowHedging          Boolean   @default(true) @map("allow_hedging")
  allowCopying          Boolean   @default(false) @map("allow_copying")
  maxLotSize            Decimal?  @map("max_lot_size") @db.Decimal(8, 2)
  allowedInstruments    String?   @map("allowed_instruments") @db.Text
  restrictedInstruments String?   @map("restricted_instruments") @db.Text
  fundedProfitTargetPct Decimal?  @map("funded_profit_target_pct") @db.Decimal(5, 2)
  fundedMaxDailyLossPct Decimal?  @map("funded_max_daily_loss_pct") @db.Decimal(5, 2)
  fundedMaxTotalLossPct Decimal?  @map("funded_max_total_loss_pct") @db.Decimal(5, 2)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  variants              ChallengeVariant[]

  @@map("challenge_rule_sets")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  COMMERCE: ORDERS, PAYMENTS, COUPONS                                    ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// A purchase intent. One order → one payment → one trader account.
model Order {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  variantId       String      @map("variant_id") @db.Uuid
  couponId        String?     @map("coupon_id") @db.Uuid
  orderNumber     String      @unique @map("order_number") @db.VarChar(30)
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency        String      @default("USD") @db.VarChar(3)
  ipAddress       String?     @map("ip_address") @db.VarChar(45)
  userAgent       String?     @map("user_agent") @db.VarChar(500)
  affiliateId     String?     @map("affiliate_id") @db.Uuid
  metadata        Json?       @db.JsonB
  paidAt          DateTime?   @map("paid_at")
  cancelledAt     DateTime?   @map("cancelled_at")
  refundedAt      DateTime?   @map("refunded_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id])
  variant         ChallengeVariant  @relation(fields: [variantId], references: [id])
  coupon          Coupon?           @relation(fields: [couponId], references: [id])
  payments        Payment[]
  traderAccount   TraderAccount?
  affiliateConversion AffiliateConversion?

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([affiliateId])
  @@index([createdAt])
  @@map("orders")
}

/// Individual payment attempt/transaction against an order.
model Payment {
  id                 String          @id @default(uuid()) @db.Uuid
  orderId            String          @map("order_id") @db.Uuid
  provider           PaymentProvider
  status             PaymentStatus   @default(PENDING)
  amount             Decimal         @db.Decimal(10, 2)
  currency           String          @default("USD") @db.VarChar(3)
  providerPaymentId  String?         @map("provider_payment_id") @db.VarChar(255)
  providerFee        Decimal?        @map("provider_fee") @db.Decimal(10, 2)
  refundedAmount     Decimal?        @map("refunded_amount") @db.Decimal(10, 2)
  failureReason      String?         @map("failure_reason") @db.VarChar(500)
  metadata           Json?           @db.JsonB
  paidAt             DateTime?       @map("paid_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  order              Order           @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerPaymentId])
  @@index([status])
  @@map("payments")
}

/// Discount codes applicable to orders.
model Coupon {
  id                String     @id @default(uuid()) @db.Uuid
  code              String     @unique @db.VarChar(50)
  type              CouponType
  value             Decimal    @db.Decimal(10, 2)
  currency          String     @default("USD") @db.VarChar(3)
  minOrderAmount    Decimal?   @map("min_order_amount") @db.Decimal(10, 2)
  maxUsageCount     Int?       @map("max_usage_count")
  usageCount        Int        @default(0) @map("usage_count")
  maxUsagePerUser   Int        @default(1) @map("max_usage_per_user")
  validFrom         DateTime   @map("valid_from")
  validUntil        DateTime?  @map("valid_until")
  isActive          Boolean    @default(true) @map("is_active")
  affiliateId       String?    @map("affiliate_id") @db.Uuid
  metadata          Json?      @db.JsonB
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  orders            Order[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  TRADER ACCOUNTS & EVALUATION                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// A provisioned trading account tied to a purchase. Moves through phases.
model TraderAccount {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  orderId         String              @unique @map("order_id") @db.Uuid
  variantId       String              @map("variant_id") @db.Uuid
  accountNumber   String              @unique @map("account_number") @db.VarChar(30)
  platform        String              @default("MT5") @db.VarChar(20)
  server          String?             @db.VarChar(100)
  login           String?             @db.VarChar(50)
  status          TraderAccountStatus @default(PROVISIONING)
  startingBalance Decimal             @map("starting_balance") @db.Decimal(14, 2)
  currentBalance  Decimal             @map("current_balance") @db.Decimal(14, 2)
  currentEquity   Decimal             @map("current_equity") @db.Decimal(14, 2)
  highWaterMark   Decimal             @map("high_water_mark") @db.Decimal(14, 2)
  currentPhase    TraderAccountPhaseType @default(PHASE_1) @map("current_phase")
  fundedAt        DateTime?           @map("funded_at")
  closedAt        DateTime?           @map("closed_at")
  closedReason    String?             @map("closed_reason") @db.VarChar(500)
  deletedAt       DateTime?           @map("deleted_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user            User                @relation(fields: [userId], references: [id])
  order           Order               @relation(fields: [orderId], references: [id])
  variant         ChallengeVariant    @relation(fields: [variantId], references: [id])
  phases          TraderAccountPhase[]
  payoutRequests  PayoutRequest[]

  @@index([userId])
  @@index([status])
  @@index([accountNumber])
  @@index([currentPhase])
  @@map("trader_accounts")
}

/// Each phase a trader account goes through. Tracks per-phase metrics.
model TraderAccountPhase {
  id                String                 @id @default(uuid()) @db.Uuid
  traderAccountId   String                 @map("trader_account_id") @db.Uuid
  phase             TraderAccountPhaseType
  status            ChallengeStatus        @default(PENDING)
  startDate         DateTime?              @map("start_date")
  endDate           DateTime?              @map("end_date")
  startingBalance   Decimal                @map("starting_balance") @db.Decimal(14, 2)
  endingBalance     Decimal?               @map("ending_balance") @db.Decimal(14, 2)
  highWaterMark     Decimal                @map("high_water_mark") @db.Decimal(14, 2)
  maxDailyDrawdown  Decimal?               @map("max_daily_drawdown") @db.Decimal(14, 2)
  maxTotalDrawdown  Decimal?               @map("max_total_drawdown") @db.Decimal(14, 2)
  totalTrades       Int                    @default(0) @map("total_trades")
  winningTrades     Int                    @default(0) @map("winning_trades")
  losingTrades      Int                    @default(0) @map("losing_trades")
  tradingDays       Int                    @default(0) @map("trading_days")
  profitLoss        Decimal                @default(0) @map("profit_loss") @db.Decimal(14, 2)
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  traderAccount     TraderAccount          @relation(fields: [traderAccountId], references: [id], onDelete: Cascade)
  evaluationResult  AccountEvaluationResult?

  @@unique([traderAccountId, phase])
  @@index([status])
  @@map("trader_account_phases")
}

/// Machine-generated eval result at the end of a phase.
model AccountEvaluationResult {
  id                String              @id @default(uuid()) @db.Uuid
  phaseId           String              @unique @map("phase_id") @db.Uuid
  verdict           EvaluationVerdict
  profitTargetMet   Boolean             @map("profit_target_met")
  dailyLossBreached Boolean             @map("daily_loss_breached")
  totalLossBreached Boolean             @map("total_loss_breached")
  minDaysMet        Boolean             @map("min_days_met")
  ruleViolations    Json?               @map("rule_violations") @db.JsonB
  evaluatedAt       DateTime            @map("evaluated_at")
  reviewedBy        String?             @map("reviewed_by") @db.Uuid
  reviewNote        String?             @map("review_note") @db.Text
  createdAt         DateTime            @default(now()) @map("created_at")

  phase             TraderAccountPhase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@map("account_evaluation_results")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  KYC / COMPLIANCE                                                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// A KYC submission bundle from a user.
model KycSubmission {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  status          KycStatus     @default(NOT_STARTED)
  documentType    KycDocumentType @map("document_type")
  documentFrontUrl String?     @map("document_front_url") @db.VarChar(500)
  documentBackUrl  String?     @map("document_back_url") @db.VarChar(500)
  selfieUrl       String?      @map("selfie_url") @db.VarChar(500)
  proofOfAddressUrl String?    @map("proof_of_address_url") @db.VarChar(500)
  fullName        String?      @map("full_name") @db.VarChar(200)
  dateOfBirth     DateTime?    @map("date_of_birth") @db.Date
  nationality     String?      @db.VarChar(2)
  documentNumber  String?      @map("document_number") @db.VarChar(50)
  documentExpiry  DateTime?    @map("document_expiry") @db.Date
  ipAddress       String?      @map("ip_address") @db.VarChar(45)
  submittedAt     DateTime?    @map("submitted_at")
  expiresAt       DateTime?    @map("expires_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user            User         @relation(fields: [userId], references: [id])
  reviews         KycReview[]

  @@index([userId])
  @@index([status])
  @@map("kyc_submissions")
}

/// Admin review action on a KYC submission.
model KycReview {
  id            String        @id @default(uuid()) @db.Uuid
  submissionId  String        @map("submission_id") @db.Uuid
  reviewerId    String        @map("reviewer_id") @db.Uuid
  decision      KycStatus
  reason        String?       @db.Text
  internalNote  String?       @map("internal_note") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  submission    KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewerId])
  @@map("kyc_reviews")
}

/// Versioned legal/compliance documents.
model LegalDocument {
  id          String            @id @default(uuid()) @db.Uuid
  type        LegalDocumentType
  version     String            @db.VarChar(20)
  title       String            @db.VarChar(200)
  content     String            @db.Text
  effectiveAt DateTime          @map("effective_at")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  consents    LegalConsent[]

  @@unique([type, version])
  @@index([type, isActive])
  @@map("legal_documents")
}

/// Immutable record of a user accepting a legal document version.
model LegalConsent {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  documentId  String        @map("document_id") @db.Uuid
  ipAddress   String        @map("ip_address") @db.VarChar(45)
  userAgent   String        @map("user_agent") @db.VarChar(500)
  consentedAt DateTime      @default(now()) @map("consented_at")

  user        User          @relation(fields: [userId], references: [id])
  document    LegalDocument @relation(fields: [documentId], references: [id])

  @@unique([userId, documentId])
  @@index([userId])
  @@map("legal_consents")
}

/// Country/region-level access restrictions.
model GeoRestriction {
  id           String          @id @default(uuid()) @db.Uuid
  countryCode  String          @unique @map("country_code") @db.VarChar(2)
  countryName  String          @map("country_name") @db.VarChar(100)
  type         RestrictionType @default(BLOCKED)
  reason       String?         @db.VarChar(500)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@map("geo_restrictions")
}

/// Feature/platform-level restrictions.
model PlatformRestriction {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  isEnabled   Boolean  @default(true) @map("is_enabled")
  description String?  @db.VarChar(500)
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("platform_restrictions")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  PAYOUTS                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// A trader's registered payout method/destination.
model PayoutMethod {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  type            PayoutMethodType
  label           String?         @db.VarChar(100)
  details         Json            @db.JsonB
  isDefault       Boolean         @default(false) @map("is_default")
  isVerified      Boolean         @default(false) @map("is_verified")
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id])
  payoutRequests  PayoutRequest[]

  @@index([userId])
  @@map("payout_methods")
}

/// A payout request from a funded trader.
model PayoutRequest {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  traderAccountId String       @map("trader_account_id") @db.Uuid
  payoutMethodId  String?      @map("payout_method_id") @db.Uuid
  requestNumber   String       @unique @map("request_number") @db.VarChar(30)
  amount          Decimal      @db.Decimal(14, 2)
  currency        String       @default("USD") @db.VarChar(3)
  profitSplit     Decimal      @map("profit_split") @db.Decimal(5, 2)
  traderShare     Decimal      @map("trader_share") @db.Decimal(14, 2)
  companyShare    Decimal      @map("company_share") @db.Decimal(14, 2)
  status          PayoutStatus @default(DRAFT)
  reviewedBy      String?      @map("reviewed_by") @db.Uuid
  reviewNote      String?      @map("review_note") @db.Text
  rejectionReason String?      @map("rejection_reason") @db.VarChar(500)
  transactionRef  String?      @map("transaction_ref") @db.VarChar(255)
  processedAt     DateTime?    @map("processed_at")
  completedAt     DateTime?    @map("completed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user            User          @relation(fields: [userId], references: [id])
  traderAccount   TraderAccount @relation(fields: [traderAccountId], references: [id])
  payoutMethod    PayoutMethod? @relation(fields: [payoutMethodId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([traderAccountId])
  @@index([createdAt])
  @@map("payout_requests")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  AFFILIATE SYSTEM                                                       ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// An approved affiliate partner account.
model AffiliateAccount {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @unique @map("user_id") @db.Uuid
  affiliateCode    String          @unique @map("affiliate_code") @db.VarChar(30)
  status           AffiliateStatus @default(PENDING)
  commissionRate   Decimal         @default(10) @map("commission_rate") @db.Decimal(5, 2)
  tier             Int             @default(1)
  totalEarnings    Decimal         @default(0) @map("total_earnings") @db.Decimal(14, 2)
  totalPaid        Decimal         @default(0) @map("total_paid") @db.Decimal(14, 2)
  pendingBalance   Decimal         @default(0) @map("pending_balance") @db.Decimal(14, 2)
  approvedAt       DateTime?       @map("approved_at")
  suspendedAt      DateTime?       @map("suspended_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  user             User            @relation(fields: [userId], references: [id])
  clicks           AffiliateClick[]
  conversions      AffiliateConversion[]
  commissionPayouts CommissionPayout[]

  @@index([affiliateCode])
  @@index([status])
  @@map("affiliate_accounts")
}

/// Click/visit tracking for affiliate links.
model AffiliateClick {
  id           String           @id @default(uuid()) @db.Uuid
  affiliateId  String           @map("affiliate_id") @db.Uuid
  ipAddress    String           @map("ip_address") @db.VarChar(45)
  userAgent    String?          @map("user_agent") @db.VarChar(500)
  referrerUrl  String?          @map("referrer_url") @db.VarChar(1000)
  landingUrl   String?          @map("landing_url") @db.VarChar(1000)
  utmSource    String?          @map("utm_source") @db.VarChar(100)
  utmMedium    String?          @map("utm_medium") @db.VarChar(100)
  utmCampaign  String?          @map("utm_campaign") @db.VarChar(100)
  fingerprint  String?          @db.VarChar(255)
  createdAt    DateTime         @default(now()) @map("created_at")

  affiliate    AffiliateAccount @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

/// An order attributed to an affiliate.
model AffiliateConversion {
  id              String                   @id @default(uuid()) @db.Uuid
  affiliateId     String                   @map("affiliate_id") @db.Uuid
  orderId         String                   @unique @map("order_id") @db.Uuid
  status          AffiliateConversionStatus @default(PENDING)
  orderAmount     Decimal                  @map("order_amount") @db.Decimal(10, 2)
  commissionRate  Decimal                  @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal                 @map("commission_amount") @db.Decimal(10, 2)
  confirmedAt     DateTime?                @map("confirmed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  affiliate       AffiliateAccount         @relation(fields: [affiliateId], references: [id])
  order           Order                    @relation(fields: [orderId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_conversions")
}

/// Batch commission payment to an affiliate.
model CommissionPayout {
  id              String                 @id @default(uuid()) @db.Uuid
  affiliateId     String                 @map("affiliate_id") @db.Uuid
  amount          Decimal                @db.Decimal(14, 2)
  currency        String                 @default("USD") @db.VarChar(3)
  status          CommissionPayoutStatus @default(PENDING)
  payoutMethod    String?                @map("payout_method") @db.VarChar(50)
  transactionRef  String?                @map("transaction_ref") @db.VarChar(255)
  processedAt     DateTime?              @map("processed_at")
  note            String?                @db.Text
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  affiliate       AffiliateAccount       @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@index([status])
  @@map("commission_payouts")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  SUPPORT                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model SupportTicket {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  assigneeId  String?        @map("assignee_id") @db.Uuid
  ticketNumber String        @unique @map("ticket_number") @db.VarChar(20)
  subject     String         @db.VarChar(255)
  category    TicketCategory @default(OTHER)
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  closedAt    DateTime?      @map("closed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user        User           @relation("TicketCreator", fields: [userId], references: [id])
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  messages    SupportMessage[]

  @@index([userId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  senderId   String   @map("sender_id") @db.Uuid
  body       String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  attachments Json?   @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [senderId], references: [id])

  @@index([ticketId])
  @@map("support_messages")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  CONTENT                                                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model BlogCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts     BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id          String         @id @default(uuid()) @db.Uuid
  authorId    String         @map("author_id") @db.Uuid
  categoryId  String?        @map("category_id") @db.Uuid
  title       String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(280)
  excerpt     String?        @db.VarChar(500)
  content     String         @db.Text
  coverImage  String?        @map("cover_image") @db.VarChar(500)
  status      BlogPostStatus @default(DRAFT)
  publishedAt DateTime?      @map("published_at")
  seoTitle    String?        @map("seo_title") @db.VarChar(255)
  seoDescription String?     @map("seo_description") @db.VarChar(500)
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  author      User           @relation(fields: [authorId], references: [id])
  category    BlogCategory?  @relation(fields: [categoryId], references: [id])

  @@index([status, publishedAt])
  @@index([slug])
  @@map("blog_posts")
}

model FAQItem {
  id          String   @id @default(uuid()) @db.Uuid
  question    String   @db.VarChar(500)
  answer      String   @db.Text
  category    String?  @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, category])
  @@map("faq_items")
}

model NewsletterSubscriber {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  isConfirmed   Boolean   @default(false) @map("is_confirmed")
  confirmedAt   DateTime? @map("confirmed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  source        String?   @db.VarChar(50)
  ipAddress     String?   @map("ip_address") @db.VarChar(45)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("newsletter_subscribers")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  NOTIFICATIONS                                                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

model Notification {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  type        NotificationType
  status      NotificationStatus @default(QUEUED)
  channel     String             @db.VarChar(50)
  title       String             @db.VarChar(255)
  body        String             @db.Text
  metadata    Json?              @db.JsonB
  sentAt      DateTime?          @map("sent_at")
  readAt      DateTime?          @map("read_at")
  failedAt    DateTime?          @map("failed_at")
  failReason  String?            @map("fail_reason") @db.VarChar(500)
  createdAt   DateTime           @default(now()) @map("created_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  SYSTEM & AUDIT                                                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝

/// Immutable audit trail of privileged actions.
model AdminActionLog {
  id           String      @id @default(uuid()) @db.Uuid
  performerId  String      @map("performer_id") @db.Uuid
  targetUserId String?     @map("target_user_id") @db.Uuid
  action       AuditAction
  resource     String      @db.VarChar(100)
  resourceId   String?     @map("resource_id") @db.Uuid
  before       Json?       @db.JsonB
  after        Json?       @db.JsonB
  ipAddress    String      @map("ip_address") @db.VarChar(45)
  userAgent    String?     @map("user_agent") @db.VarChar(500)
  metadata     Json?       @db.JsonB
  createdAt    DateTime    @default(now()) @map("created_at")

  performer    User        @relation("ActionPerformer", fields: [performerId], references: [id])
  targetUser   User?       @relation("ActionTarget", fields: [targetUserId], references: [id])

  @@index([performerId])
  @@index([targetUserId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("admin_action_logs")
}

/// Key-value system configuration store.
model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  dataType    String   @default("string") @map("data_type") @db.VarChar(20)
  description String?  @db.VarChar(500)
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
