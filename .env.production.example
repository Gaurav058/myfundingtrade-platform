# ─── Global ───────────────────────────────────────────────
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://mft_prod:CHANGE_ME@postgres:5432/myfundingtrade?schema=public
POSTGRES_USER=mft_prod
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=myfundingtrade

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ─── API ──────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
COOKIE_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING
COOKIE_DOMAIN=.myfundingtrade.com

# ─── URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.myfundingtrade.com
NEXT_PUBLIC_APP_URL=https://myfundingtrade.com
NEXT_PUBLIC_PORTAL_URL=https://portal.myfundingtrade.com
NEXT_PUBLIC_ADMIN_URL=https://admin.myfundingtrade.com
ALLOWED_ORIGINS=https://myfundingtrade.com,https://portal.myfundingtrade.com,https://admin.myfundingtrade.com

# ─── Email ────────────────────────────────────────────────
RESEND_API_KEY=CHANGE_ME
EMAIL_FROM=MyFundingTrade <noreply@myfundingtrade.com>

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ─── S3 / Object Storage (optional) ──────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
