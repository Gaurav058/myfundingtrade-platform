# ─── Global ───────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myfundingtrade?schema=public

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ──────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Next.js Public (apps/web) ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Next.js Public (apps/portal) ────────────────────────
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001

# ─── Next.js Public (apps/admin) ─────────────────────────
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ─── Email / SMTP ────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=MyFundingTrade <noreply@myfundingtrade.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@myfundingtrade.com

# ─── Payment ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Storage (S3-compatible) ─────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
