# ─── Global ───────────────────────────────────────────────
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://mft_staging:staging_password@postgres:5432/myfundingtrade_staging?schema=public
POSTGRES_USER=mft_staging
POSTGRES_PASSWORD=staging_password
POSTGRES_DB=myfundingtrade_staging

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── API ──────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=staging-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
COOKIE_SECRET=staging-cookie-secret-change-in-production
COOKIE_DOMAIN=.staging.myfundingtrade.com

# ─── URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.staging.myfundingtrade.com
NEXT_PUBLIC_APP_URL=https://staging.myfundingtrade.com
NEXT_PUBLIC_PORTAL_URL=https://portal.staging.myfundingtrade.com
NEXT_PUBLIC_ADMIN_URL=https://admin.staging.myfundingtrade.com
ALLOWED_ORIGINS=https://staging.myfundingtrade.com,https://portal.staging.myfundingtrade.com,https://admin.staging.myfundingtrade.com

# ─── Email (use test mode) ───────────────────────────────
RESEND_API_KEY=re_test_CHANGE_ME
EMAIL_FROM=MyFundingTrade Staging <noreply@staging.myfundingtrade.com>

# ─── Stripe (test mode) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
